datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

// ==========================================
// SYSTEM ENUMS
// ==========================================

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum RelationType {
  RELATED
  REFERENCES
  DEPENDS_ON
  PREREQUISITE
  NEXT
  PREVIOUS
}

enum UsageEvent {
  VIEW
  OPEN
  DOWNLOAD
  SHARE
  LIKE
  BOOKMARK
}

enum ResourceType {
  ARTICLE
  NOTE
  MODULE
  VIDEO
  IMAGE
  FILE
  LINK
  AI_OUTPUT
}

// ==========================================
// CORE IDENTITY & ACCOUNT LAYERS
// ==========================================

model User {
  id           String  @id @default(uuid(7))
  tenantId     String? // Core tenant isolation discriminator
  identityId   String? @unique
  username     String  @unique
  email        String  @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  bio          String?

  // Onboarding Hard-Lock state machines
  onboardingStep Int   @default(0)
  onboardingJson Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  deletedAt  DateTime?

  // Graph Relationships
  resources      Resource[]
  collections    Collection[]
  comments       Comment[]
  savedResources SavedResource[]
  usageEvents    ResourceUsage[]
  versions       ResourceVersion[]

  @@index([username])
  @@index([email])
  @@index([tenantId])
  @@index([deletedAt])
}

// ==========================================
// THE KNOWLEDGE GRAPH NODE CONTAINER
// ==========================================

model Resource {
  id          String  @id @default(uuid(7))
  tenantId    String? // Grouping partition boundary
  slug        String?
  title       String?
  description String?
  excerpt     String?

  // Live Publishing Fork Strategy
  publishedContentJson Json?
  draftContentJson     Json?
  content              String? // Fallback raw string for pg_trgm text search

  type          ResourceType
  status        ResourceStatus @default(DRAFT)
  visibility    Visibility     @default(PUBLIC)
  category      String?
  language      String?        @default("en")
  thumbnailUrl  String?
  coverImageUrl String?
  fileUrl       String?
  metadata      Json?
  aiMetadata    Json? // Dedicated storage block for Vector embeddings & AI context

  wordCount     Int?
  estimatedTime Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?
  archivedAt    DateTime?
  deletedAt     DateTime?

  // Hierarchical Self-Reference Tree
  authorId String
  author   User       @relation(fields: [authorId], references: [id])
  parentId String?
  parent   Resource?  @relation("Hierarchy", fields: [parentId], references: [id])
  children Resource[] @relation("Hierarchy")

  // Explicit DAG Edge Graph Maps
  outgoingRelations Relation[] @relation("From")
  incomingRelations Relation[] @relation("To")

  // Auxiliary Relations
  tags        Tag[]
  collections CollectionResource[]
  comments    Comment[]
  metrics     ResourceMetrics?
  versions    ResourceVersion[]
  usageEvents ResourceUsage[]
  savedBy     SavedResource[]

  // Optimizations: Slugs are unique per author within a tenant organization boundary
  @@unique([tenantId, authorId, slug])
  @@index([type, status])
  @@index([tenantId])
  @@index([deletedAt])
}

// ==========================================
// GRAPH EDGES & HISTORY
// ==========================================

model Relation {
  id        String       @id @default(uuid(7))
  type      RelationType
  fromId    String
  toId      String
  metadata  Json? // Weights, custom sequences, sequence priorities
  createdAt DateTime     @default(now())

  from Resource @relation("From", fields: [fromId], references: [id], onDelete: Cascade)
  to   Resource @relation("To", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, type])
  @@index([toId]) // Accelerates backward-lookup dependency queries
}

model ResourceVersion {
  id            String   @id @default(uuid(7))
  resourceId    String
  authorId      String
  versionNumber Int
  title         String
  content       String?
  contentJson   Json?
  changeSummary String?
  createdAt     DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@unique([resourceId, versionNumber])
}

// ==========================================
// CONTAINERS & TAXONOMY LAYERS
// ==========================================

model Collection {
  id          String     @id @default(uuid(7))
  tenantId    String? // Isolated tenant filter field
  slug        String
  title       String
  description String?
  visibility  Visibility @default(PUBLIC)
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  authorId  String
  author    User                 @relation(fields: [authorId], references: [id])
  resources CollectionResource[]

  @@unique([tenantId, authorId, slug])
  @@index([tenantId])
  @@index([deletedAt])
}

model CollectionResource {
  id           String   @id @default(uuid(7))
  collectionId String
  resourceId   String
  orderIndex   Int
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  resource   Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([collectionId, resourceId])
  @@index([collectionId, orderIndex]) // Optimized index for sequential ordered reads
}

model Tag {
  id        String   @id @default(uuid(7))
  tenantId  String? // Enforces tenant separation for tag namespaces
  name      String
  slug      String
  createdAt DateTime @default(now())

  resources Resource[]

  @@unique([tenantId, slug])
  @@unique([tenantId, name])
  @@index([tenantId])
}

// ==========================================
// TELEMETRY & ENGAGEMENT HOOKS
// ==========================================

model Comment {
  id        String        @id @default(uuid(7))
  content   String
  status    CommentStatus @default(ACTIVE)
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  authorId   String
  resourceId String
  parentId   String?

  author   User      @relation(fields: [authorId], references: [id])
  resource Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("Thread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  Comment[] @relation("Thread")

  @@index([resourceId, createdAt]) // Instant chronological thread reads
}

model SavedResource {
  id         String   @id @default(uuid(7))
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model ResourceUsage {
  id         String     @id @default(uuid(7))
  resourceId String
  userId     String?
  event      UsageEvent
  sessionId  String?
  metadata   Json?
  createdAt  DateTime   @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([resourceId, event]) // High-concurrency aggregate counter index
  @@index([userId])
  @@index([createdAt]) // Essential performance index for background batch processors
}

model ResourceMetrics {
  id              String   @id @default(uuid(7))
  resourceId      String   @unique
  views           Int      @default(0)
  opens           Int      @default(0)
  downloads       Int      @default(0)
  shares          Int      @default(0)
  likes           Int      @default(0)
  bookmarks       Int      @default(0)
  engagementScore Float    @default(0)
  updatedAt       DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}
